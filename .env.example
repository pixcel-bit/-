# Claude API (必須)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI TTS API (任意 - 未設定時はgTTSにフォールバック)
OPENAI_API_KEY=your_openai_api_key_here

# TTS プロバイダー: "openai" または "gtts" (デフォルト: gtts)
TTS_PROVIDER=gtts

# ニュース収集スケジュール (cron形式, デフォルト: 毎朝6時)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# デモモード (RSSが取得できない環境ではtrueに設定)
DEMO_MODE=false

# サーバー設定
HOST=0.0.0.0
PORT=8000
